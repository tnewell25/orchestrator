# ---- App ----
AGENT_NAME=Orchestrator
ENVIRONMENT=production
PORT=8000

# ---- LLM (choose one path) ----
# A. Claude Max OAuth (recommended — uses your subscription, no per-token billing)
# Run `python -m orchestrator.bootstrap_oauth` to obtain these, or sync from ~/.claude/.credentials.json
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_REFRESH_TOKEN=
# B. API key (fallback)
ANTHROPIC_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-5-20250929
FAST_MODEL=claude-haiku-4-5-20251001

# ---- Database ----
# Local dev: postgres://orchestrator:orchestrator@localhost:5432/orchestrator
# Railway: will be injected as DATABASE_URL
DATABASE_URL=

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to message the bot.
# Get yours by DM-ing @userinfobot.
TELEGRAM_ALLOWED_USERS=

# ---- Voice transcription (optional, enables voice note capture) ----
OPENAI_API_KEY=

# ---- Google Workspace (optional — for Gmail + Calendar integration) ----
GOOGLE_CREDENTIALS_PATH=
GOOGLE_USER_EMAIL=
